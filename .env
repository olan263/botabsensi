# ==========================================================
# TEMPLATE KONFIGURASI - JANGAN diisi di sini, JANGAN di-commit ke Git!
# ==========================================================
# Cara pakai:
#   1. Copy file ini jadi ".env" (bukan ".env.example") di folder yang sama dgn bot.py
#      cp .env.example .env
#   2. Isi nilai ASLI di file ".env" (bukan di file ini)
#   3. Tambahkan baris ".env" ke file .gitignore
# ==========================================================

# Token BARU hasil revoke dari @BotFather (bukan token lama yang sudah bocor)
BOT_TOKEN=8826307677:AAG5XscgHtD6eY0sOS8eK1g2UQEjI5DM0Xk

# ID grup Telegram tujuan notifikasi & rekap otomatis (angka negatif, dari /grupid)
GROUP_CHAT_ID=-5591365135

# Password PostgreSQL yang BARU (bukan password lama yang sudah bocor)
DB_PASSWORD=140505

# Opsional, isi kalau beda dari default
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=absensi_karyawan
# DB_USER=postgres

# ==========================================================
# GOOGLE SHEETS (opsional) - kosongkan kalau tidak mau pakai fitur auto-sync
# ==========================================================
# Path ke file JSON kunci Service Account (dari Google Cloud Console).
# Taruh file JSON ini di folder bot, JANGAN commit ke Git (tambahkan ke .gitignore).
GOOGLE_SHEETS_CREDENTIALS_FILE=service_account.json

# ID spreadsheet tujuan, diambil dari URL Google Sheets, contoh:
# https://docs.google.com/spreadsheets/d/INI_ID_NYA/edit -> ambil bagian INI_ID_NYA
GOOGLE_SHEETS_ID=1Tmb--PxJG9N631ZVLYn_UVS0Ywa02a3oKf-0R9rQZQw
